<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:StudyCompanion"
             xmlns:localization="clr-namespace:StudyCompanion.Resources.Strings"
             x:Class="StudyCompanion.OperatingSystemsExercisesPage"
             Title="{x:Static localization:AppResources.OperatingSystems}">

    <ContentPage.Content>
        <TableView Intent="Menu">
            <TableRoot>
                <TableSection Title="{x:Static localization:AppResources.OperatingSystems}">
                    <TextCell Text="{x:Static localization:AppResources.PageReplacement}" Command="{Binding NavigateCommand}" CommandParameter="{x:Type local:PageReplacementPage}" />
                    <TextCell Text="{x:Static localization:AppResources.Buddy}" Command="{Binding NavigateCommand}" CommandParameter="{x:Type local:BuddyPage}" />
                    <TextCell Text="{x:Static localization:AppResources.Scheduling}" Command="{Binding NavigateCommand}" CommandParameter="{x:Type local:SchedulingPage}" />
                    <TextCell Text="{x:Static localization:AppResources.RealtimeScheduling}" Command="{Binding NavigateCommand}" CommandParameter="{x:Type local:RealtimeSchedulingPage}" />
                </TableSection>
            </TableRoot>
        </TableView>
    </ContentPage.Content>
</ContentPage>