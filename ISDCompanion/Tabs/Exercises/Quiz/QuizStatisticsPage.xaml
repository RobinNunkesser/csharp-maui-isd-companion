<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:StudyCompanion"
             xmlns:localization="clr-namespace:StudyCompanion.Resources.Strings"
             x:Class="StudyCompanion.QuizStatisticsPage"
             x:DataType="local:QuizViewModel"
                      Title="{x:Static localization:AppResources.title_statistics}"
                      BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#0F172A}">
    <ContentPage.Content>
              <ScrollView>
                     <VerticalStackLayout Padding="20" Spacing="16">
                            <Border Padding="20" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}" Stroke="{AppThemeBinding Light=#D9E3F0, Dark=#334155}" StrokeThickness="1">
                                   <Border.StrokeShape>
                                          <RoundRectangle CornerRadius="24" />
                                   </Border.StrokeShape>
                                   <VerticalStackLayout Spacing="6">
                                          <Label Text="{x:Static localization:AppResources.title_statistics}"
                                                    FontSize="28"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />
                                          <Label Text="{Binding CatalogSummaryText}"
                                                    FontSize="14"
                                                    TextColor="{AppThemeBinding Light=#486581, Dark=#CBD5E1}" />
                                   </VerticalStackLayout>
                            </Border>

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                   <Border Grid.Row="0" Grid.Column="0" Padding="16" BackgroundColor="{AppThemeBinding Light=#F0FDF4, Dark=#052E16}" Stroke="{AppThemeBinding Light=#B7E4C7, Dark=#166534}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.label_sum}" FontSize="12" TextColor="{AppThemeBinding Light=#52796F, Dark=#86EFAC}" />
                                                 <Label Text="{Binding AnsweredQuestions}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1B4332, Dark=#DCFCE7}" />
                                          </VerticalStackLayout>
                                   </Border>
                                   <Border Grid.Row="0" Grid.Column="1" Padding="16" BackgroundColor="{AppThemeBinding Light=#ECFDF5, Dark=#064E3B}" Stroke="{AppThemeBinding Light=#A7F3D0, Dark=#10B981}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.label_correct}" FontSize="12" TextColor="{AppThemeBinding Light=#065F46, Dark=#6EE7B7}" />
                                                 <Label Text="{Binding CorrectAnswers}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#065F46, Dark=#D1FAE5}" />
                                          </VerticalStackLayout>
                                   </Border>
                                   <Border Grid.Row="1" Grid.Column="0" Padding="16" BackgroundColor="{AppThemeBinding Light=#FEF2F2, Dark=#450A0A}" Stroke="{AppThemeBinding Light=#FECACA, Dark=#DC2626}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.label_wrong}" FontSize="12" TextColor="{AppThemeBinding Light=#991B1B, Dark=#FCA5A5}" />
                                                 <Label Text="{Binding WrongAnswers}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#991B1B, Dark=#FEE2E2}" />
                                          </VerticalStackLayout>
                                   </Border>
                                   <Border Grid.Row="1" Grid.Column="1" Padding="16" BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#431407}" Stroke="{AppThemeBinding Light=#FED7AA, Dark=#EA580C}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.label_skipped}" FontSize="12" TextColor="{AppThemeBinding Light=#9A3412, Dark=#FDBA74}" />
                                                 <Label Text="{Binding SkippedQuestions}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#9A3412, Dark=#FFEDD5}" />
                                          </VerticalStackLayout>
                                   </Border>
                                   <Border Grid.Row="2" Grid.Column="0" Padding="16" BackgroundColor="{AppThemeBinding Light=#EEF2FF, Dark=#1E1B4B}" Stroke="{AppThemeBinding Light=#C7D2FE, Dark=#6366F1}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.QuizBestStreak}" FontSize="12" TextColor="{AppThemeBinding Light=#3730A3, Dark=#A5B4FC}" />
                                                 <Label Text="{Binding BestStreak}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#312E81, Dark=#E0E7FF}" />
                                          </VerticalStackLayout>
                                   </Border>
                                   <Border Grid.Row="2" Grid.Column="1" Padding="16" BackgroundColor="{AppThemeBinding Light=#FDF2F8, Dark=#4A044E}" Stroke="{AppThemeBinding Light=#FBCFE8, Dark=#DB2777}">
                                          <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                          <VerticalStackLayout Spacing="4">
                                                 <Label Text="{x:Static localization:AppResources.QuizAccuracy}" FontSize="12" TextColor="{AppThemeBinding Light=#9D174D, Dark=#F9A8D4}" />
                                                 <Label Text="{Binding AccuracyText}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#831843, Dark=#FCE7F3}" />
                                          </VerticalStackLayout>
                                   </Border>
                            </Grid>

                            <Border Padding="18" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}" Stroke="{AppThemeBinding Light=#D9E3F0, Dark=#334155}" StrokeThickness="1">
                                   <Border.StrokeShape>
                                          <RoundRectangle CornerRadius="22" />
                                   </Border.StrokeShape>
                                   <VerticalStackLayout Spacing="12">
                                          <Grid ColumnDefinitions="*,Auto">
                                                 <Label Text="{x:Static localization:AppResources.QuizLifetimeStats}"
                                                        FontAttributes="Bold"
                                                        TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />
                                                 <Button Grid.Column="1"
                                                         Text="{x:Static localization:AppResources.QuizResetHistory}"
                                                         Command="{Binding ResetHistoryCommand}"
                                                         BackgroundColor="{AppThemeBinding Light=#FEE2E2, Dark=#7F1D1D}"
                                                         TextColor="{AppThemeBinding Light=#991B1B, Dark=#FEE2E2}"
                                                         CornerRadius="18"
                                                         Padding="12,8" />
                                          </Grid>
                                          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                                 <Border Grid.Row="0" Grid.Column="0" Padding="14" BackgroundColor="{AppThemeBinding Light=#EFF6FF, Dark=#1E3A8A}" Stroke="{AppThemeBinding Light=#BFDBFE, Dark=#60A5FA}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="4">
                                                               <Label Text="{x:Static localization:AppResources.QuizSessionsPlayed}" FontSize="12" TextColor="{AppThemeBinding Light=#1D4ED8, Dark=#BFDBFE}" />
                                                               <Label Text="{Binding LifetimeSessionsPlayed}" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1E3A8A, Dark=#EFF6FF}" />
                                                        </VerticalStackLayout>
                                                 </Border>
                                                 <Border Grid.Row="0" Grid.Column="1" Padding="14" BackgroundColor="{AppThemeBinding Light=#F5F3FF, Dark=#3B0764}" Stroke="{AppThemeBinding Light=#DDD6FE, Dark=#8B5CF6}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="4">
                                                               <Label Text="{x:Static localization:AppResources.QuizAccuracy}" FontSize="12" TextColor="{AppThemeBinding Light=#6D28D9, Dark=#DDD6FE}" />
                                                               <Label Text="{Binding LifetimeAccuracyText}" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#5B21B6, Dark=#F5F3FF}" />
                                                        </VerticalStackLayout>
                                                 </Border>
                                                 <Border Grid.Row="1" Grid.Column="0" Padding="14" BackgroundColor="{AppThemeBinding Light=#ECFDF5, Dark=#064E3B}" Stroke="{AppThemeBinding Light=#A7F3D0, Dark=#10B981}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="4">
                                                               <Label Text="{x:Static localization:AppResources.QuizBestStreak}" FontSize="12" TextColor="{AppThemeBinding Light=#047857, Dark=#6EE7B7}" />
                                                               <Label Text="{Binding LifetimeBestStreak}" FontSize="22" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#065F46, Dark=#D1FAE5}" />
                                                        </VerticalStackLayout>
                                                 </Border>
                                                 <Border Grid.Row="1" Grid.Column="1" Padding="14" BackgroundColor="{AppThemeBinding Light=#FFF7ED, Dark=#431407}" Stroke="{AppThemeBinding Light=#FED7AA, Dark=#EA580C}">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="4">
                                                               <Label Text="{x:Static localization:AppResources.QuizLastPlayed}" FontSize="12" TextColor="{AppThemeBinding Light=#C2410C, Dark=#FDBA74}" />
                                                               <Label Text="{Binding LastPlayedText}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#9A3412, Dark=#FFEDD5}" />
                                                        </VerticalStackLayout>
                                                 </Border>
                                          </Grid>
                                          <Grid ColumnDefinitions="*,Auto">
                                                 <Label Text="{x:Static localization:AppResources.QuizCompletion}" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />
                                                 <Label Grid.Column="1" Text="{Binding LifetimeCompletionText}" TextColor="{AppThemeBinding Light=#486581, Dark=#CBD5E1}" />
                                          </Grid>
                                          <ProgressBar Progress="{Binding LifetimeCompletionRatio}" ProgressColor="{AppThemeBinding Light=#2F855A, Dark=#4ADE80}" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" HeightRequest="10" />
                                   </VerticalStackLayout>
                            </Border>

                            <Border Padding="18" BackgroundColor="{AppThemeBinding Light=White, Dark=#111827}" Stroke="{AppThemeBinding Light=#D9E3F0, Dark=#334155}" StrokeThickness="1">
                                   <Border.StrokeShape>
                                          <RoundRectangle CornerRadius="22" />
                                   </Border.StrokeShape>
                                   <VerticalStackLayout Spacing="14">
                                          <Label Text="{x:Static localization:AppResources.Quiz}"
                                                    FontAttributes="Bold"
                                                    TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />

                                          <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" RowSpacing="10" ColumnSpacing="12">
                                                 <Label Grid.Row="0" Text="{x:Static localization:AppResources.label_correct}" TextColor="{AppThemeBinding Light=#486581, Dark=#CBD5E1}" />
                                                 <ProgressBar Grid.Row="0" Grid.Column="1" Progress="{Binding CorrectRatio}" ProgressColor="{AppThemeBinding Light=#16A34A, Dark=#4ADE80}" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" HeightRequest="8" VerticalOptions="Center" />
                                                 <Label Grid.Row="0" Grid.Column="2" Text="{Binding CorrectAnswers}" TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />

                                                 <Label Grid.Row="1" Text="{x:Static localization:AppResources.label_wrong}" TextColor="{AppThemeBinding Light=#486581, Dark=#CBD5E1}" />
                                                 <ProgressBar Grid.Row="1" Grid.Column="1" Progress="{Binding WrongRatio}" ProgressColor="{AppThemeBinding Light=#DC2626, Dark=#F87171}" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" HeightRequest="8" VerticalOptions="Center" />
                                                 <Label Grid.Row="1" Grid.Column="2" Text="{Binding WrongAnswers}" TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />

                                                 <Label Grid.Row="2" Text="{x:Static localization:AppResources.label_skipped}" TextColor="{AppThemeBinding Light=#486581, Dark=#CBD5E1}" />
                                                 <ProgressBar Grid.Row="2" Grid.Column="1" Progress="{Binding SkippedRatio}" ProgressColor="{AppThemeBinding Light=#D97706, Dark=#FB923C}" BackgroundColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" HeightRequest="8" VerticalOptions="Center" />
                                                 <Label Grid.Row="2" Grid.Column="2" Text="{Binding SkippedQuestions}" TextColor="{AppThemeBinding Light=#102A43, Dark=#F8FAFC}" />
                                          </Grid>
                                   </VerticalStackLayout>
                            </Border>
                     </VerticalStackLayout>
              </ScrollView>
    </ContentPage.Content>
</ContentPage>
