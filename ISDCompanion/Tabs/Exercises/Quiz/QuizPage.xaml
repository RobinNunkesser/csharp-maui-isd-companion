<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:StudyCompanion"
             xmlns:localization="clr-namespace:StudyCompanion.Resources.Strings"
             x:Class="StudyCompanion.QuizPage"
             x:DataType="local:QuizViewModel"
             Title="{x:Static localization:AppResources.Quiz}"
             BackgroundColor="#F4F7FB">
    <ContentPage.ToolbarItems>
        <ToolbarItem IconImageSource="statistics"
                     Clicked="Statistics_Clicked" />
    </ContentPage.ToolbarItems>
    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">
                <Border Padding="20" BackgroundColor="White" Stroke="#D9E3F0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{x:Static localization:AppResources.Quiz}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Label Text="{Binding CatalogSummaryText}"
                               FontSize="14"
                               TextColor="#486581" />
                        <Label Text="{Binding SessionStatusText}"
                               FontSize="15"
                               TextColor="#334E68" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="18" BackgroundColor="#EEF6FF" Stroke="#C9DEFF" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                        <Label Text="{x:Static localization:AppResources.QuizCatalog}"
                               FontAttributes="Bold"
                               TextColor="#102A43" />
                        <Button Grid.Column="1"
                                Text="{x:Static localization:AppResources.QuizRestart}"
                                Command="{Binding RestartQuizCommand}"
                                BackgroundColor="#DCEBFF"
                                TextColor="#0B3C6F"
                                CornerRadius="18"
                                Padding="14,8" />
                        <Picker Grid.Row="1"
                                Grid.ColumnSpan="2"
                                ItemsSource="{Binding CatalogNames}"
                                SelectedIndex="{Binding SelectedCatalogIndex}"
                                BackgroundColor="White"
                                TextColor="#102A43"
                                Title="{x:Static localization:AppResources.QuizCatalog}" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <Border Grid.Row="0" Grid.Column="0" Padding="16" BackgroundColor="#F0FDF4" Stroke="#B7E4C7">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static localization:AppResources.label_sum}" FontSize="12" TextColor="#52796F" />
                            <Label Text="{Binding AnsweredQuestions}" FontSize="26" FontAttributes="Bold" TextColor="#1B4332" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" Padding="16" BackgroundColor="#FFF7E8" Stroke="#F4D58D">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static localization:AppResources.QuizAccuracy}" FontSize="12" TextColor="#9C6644" />
                            <Label Text="{Binding AccuracyText}" FontSize="26" FontAttributes="Bold" TextColor="#7F5539" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" Padding="16" BackgroundColor="#EEF2FF" Stroke="#C7D2FE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static localization:AppResources.QuizRemaining}" FontSize="12" TextColor="#4C51BF" />
                            <Label Text="{Binding RemainingQuestions}" FontSize="26" FontAttributes="Bold" TextColor="#3730A3" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" Padding="16" BackgroundColor="#FDF2F8" Stroke="#FBCFE8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static localization:AppResources.QuizCurrentStreak}" FontSize="12" TextColor="#9D174D" />
                            <Label Text="{Binding CurrentStreak}" FontSize="26" FontAttributes="Bold" TextColor="#831843" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Padding="18" BackgroundColor="White" Stroke="#D9E3F0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{x:Static localization:AppResources.QuizCompletion}"
                                   FontAttributes="Bold"
                                   TextColor="#102A43" />
                            <Label Grid.Column="1"
                                   Text="{Binding CompletionText}"
                                   TextColor="#486581" />
                        </Grid>
                        <ProgressBar Progress="{Binding CompletionRatio}"
                                     ProgressColor="#2F855A"
                                     BackgroundColor="#E2E8F0"
                                     HeightRequest="10" />
                    </VerticalStackLayout>
                </Border>

                <Border Padding="20" BackgroundColor="White" Stroke="#D9E3F0" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="{Binding QuestionNumberText}"
                               FontSize="13"
                               TextColor="#486581"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Question}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#102A43"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="answerLabel"
                               Text="{Binding Answer}"
                               TextColor="{Binding FeedbackColor}"
                               IsVisible="{Binding HasFeedback}"
                               Opacity="0"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="{x:Static localization:AppResources.Wrong}"
                                    IsEnabled="{Binding ButtonsEnabled}"
                                    Clicked="Wrong_Clicked"
                                    BackgroundColor="#FEE2E2"
                                    TextColor="#991B1B"
                                    CornerRadius="20"
                                    Padding="16,14" />
                            <Button Grid.Column="1"
                                    Text="{x:Static localization:AppResources.Right}"
                                    IsEnabled="{Binding ButtonsEnabled}"
                                    Clicked="Right_Clicked"
                                    BackgroundColor="#DCFCE7"
                                    TextColor="#166534"
                                    CornerRadius="20"
                                    Padding="16,14" />
                        </Grid>
                        <Button Text="{x:Static localization:AppResources.Skip}"
                                IsEnabled="{Binding ButtonsEnabled}"
                                Clicked="Skip_Clicked"
                                BackgroundColor="#E2E8F0"
                                TextColor="#334E68"
                                CornerRadius="20"
                                Padding="16,14" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>